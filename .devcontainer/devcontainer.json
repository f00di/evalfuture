{
  "name": "Evalfuture",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "postCreateCommand": "cd backend && python -m pip install -r requirements.txt && cd ../frontend && npm ci",
  "forwardPorts": [3000, 8000],
  "portsAttributes": {
    "3000": {
      "label": "Evalfuture frontend",
      "onAutoForward": "openPreview"
    },
    "8000": {
      "label": "Evalfuture API",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
